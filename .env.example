# ─── Required ─────────────────────────────────────────────────────────────────
# MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/)
MONGODB_URI=

# MongoDB database name (defaults to "notes-app" if not set)
MONGODB_DB=notes-app

# Shared secret between Next.js frontend and this Go API.
# Must match INTERNAL_API_KEY in the Next.js project.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=

# ─── Local Dev Only ────────────────────────────────────────────────────────────
# Port for the local dev server (go run ./cmd/dev-api). Defaults to 4000.
# PORT=4000
